rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Validation for user profile creation
    function isValidProfileCreate(userId) {
      return request.resource.data.userId == userId
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && request.resource.data.createdAt != null;
    }

    // USER DATA: Private to each user
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidProfileCreate(userId);
      allow update: if isOwner(userId)
        && request.resource.data.userId == userId; 
      allow delete: if false; 
    }

    // WALLETS: Only owner can read, but NO ONE can update from client-side
    // Balance updates must happen via backend (Admin SDK)
    match /wallets/{userId} {
      allow read: if isOwner(userId);
      allow write: if false; // Strict: Backend only updates
    }

    // WALLET TRANSACTIONS: Only owner can read his transactions
    match /walletTransactions/{txId} {
      allow read: if isOwner(resource.data.userId);
      allow write: if false; // Strict: Backend only
    }

    // PAYMENT ORDERS: Only owner can read, but status updates are backend-only
    match /paymentOrders/{orderId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if false; // Order creation happens via backend API
      allow update, delete: if false; // Status updates via webhook (backend)
    }

    // GYM MEMBERS: Used for dashboard demo
    match /gymMembers/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
    }

    // CLASS BOOKINGS: Future feature
    match /classBookings/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    // LIVE ANNOUNCEMENTS: Publicly readable, admin writable
    match /liveAnnouncements/{docId} {
      allow read: if true; // Everyone can see gym announcements
      // In a real app, you would check for an 'admin' role in request.auth.token or a users document
      allow write: if isSignedIn()
        && request.auth.token.admin == true;
    }
  }
}
